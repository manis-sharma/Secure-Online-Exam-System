# Firebase Environment Configuration
# Copy this file to .env and fill in your Firebase project credentials

REACT_APP_FIREBASE_API_KEY=your-api-key-here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id

# Optional: Restrict login to specific school domain (without @)
# Leave empty to allow all Google accounts
REACT_APP_ALLOWED_DOMAIN=

# Exam Configuration
REACT_APP_QUESTION_TIME_LIMIT=30
REACT_APP_TAB_SWITCH_PENALTY_TIME=10
